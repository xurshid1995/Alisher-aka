# ============================================
# DATABASE SOZLAMALARI
# ============================================
DATABASE_URL=postgresql://user:password@localhost/dbname

# ============================================
# TELEGRAM BOT SOZLAMALARI
# ============================================

# Bot token (BotFather dan olinadi)
# @BotFather ga /newbot yuboring va bot yarating
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin chat IDs (vergul bilan ajratilgan)
# @userinfobot ga /start yuboring va chat ID ni oling
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# ============================================
# QARZ ESLATMALARI SOZLAMALARI
# ============================================

# Kunlik eslatmalar vaqti (HH:MM format)
DEBT_REMINDER_TIME=10:00

# Haftalik hisobot kuni (0=Yakshanba, 1=Dushanba, ..., 6=Shanba)
WEEKLY_REPORT_DAY=1

# Minimal qarz miqdori (USD)
MINIMUM_DEBT_AMOUNT=1.0

# ============================================
# FLASK SOZLAMALARI
# ============================================
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
DEBUG=False

# ============================================
# HOSTING TO'LOV BOT SOZLAMALARI
# ============================================

# Hosting bot token (BotFather dan yangi bot yarating)
HOSTING_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin Telegram chat ID (faqat bitta admin)
HOSTING_ADMIN_CHAT_ID=123456789

# To'lov kartasi ma'lumotlari
HOSTING_CARD_NUMBER=8600123456789012
HOSTING_CARD_OWNER=ANUROV XURSHID

# Card Xabar bot chat ID (agar guruhda bo'lsa)
CARD_XABAR_CHAT_ID=0

# To'lov moslashtirish vaqt oynasi (daqiqa)
PAYMENT_MATCH_WINDOW=30

# DigitalOcean API token
DO_API_TOKEN=dop_v1_your_token_here

# To'lov muddati o'tganidan keyin serverga kutish kuni
HOSTING_GRACE_DAYS=3
